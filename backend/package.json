{
  "name": "chatapp-backend",
  "version": "1.0.0",
  "description": "Real-time chat app backend (Cloudflare Worker)",
  "type": "module",
  "main": "worker.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
