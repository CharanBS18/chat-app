    "dev:worker": "wrangler dev",
    "deploy:prod": "wrangler publish --env production"
  },
  "dependencies": {
    "itty-router": "^4.0.0"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
